# Wind Framework 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# HTTP 服务器配置
HTTP_SERVER_LISTEN=0.0.0.0:2333

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wind_chat
DB_USERNAME=root
DB_PASSWORD=

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Tavily Search API 配置
# 获取 API 密钥：https://tavily.com/
TAVILY_API_KEY=
TAVILY_TIMEOUT=30
TAVILY_MAX_RESULTS=10

# MiniMax API 配置
# 获取 API 密钥：https://www.minimaxi.com/
MINIMAX_API_KEY=

# DeepSeek API 配置
# 获取 API 密钥：https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 智谱 AI API 配置
# 获取 API 密钥：https://open.bigmodel.cn/
ZHIPU_API_KEY=

# MCP (Model Context Protocol) 服务器配置
# 文档：https://modelcontextprotocol.io/

# === MCP 全局配置 ===
MCP_TIMEOUT=30
MCP_REQUEST_TIMEOUT=60
MCP_MAX_RETRIES=3
MCP_CONTINUE_ON_ERROR=true

# === MCP 服务器配置 ===
# 启用服务器：设置 MCP_<SERVER_NAME>=true

# Brave 搜索服务器
# 获取 API 密钥：https://search.brave.com/search/api
MCP_BRAVE_SEARCH=false
MCP_BRAVE_SEARCH_API_KEY=

# GitHub 服务器
# 获取 Personal Access Token：https://github.com/settings/tokens
MCP_GITHUB=false
MCP_GITHUB_TOKEN=

# Fetch HTTP 请求服务器
MCP_FETCH=false

# Memory 内存存储服务器
MCP_MEMORY=false

# MiniMax 编码计划服务器
# 获取 API 密钥：https://www.minimaxi.com/
MCP_MINIMAX=false
MINIMAX_API_HOST=https://api.minimaxi.com
MINIMAX_API_KEY=

# Exa HTTP MCP 服务器
# 获取 API 密钥：https://exa.ai/
MCP_EXA=false
MCP_EXA_API_KEY=

# 智谱 AI Web Reader 服务器
# 获取 API 密钥：https://open.bigmodel.cn/
MCP_ZHIPU_WEB_READER=false
MCP_ZHIPU_WEB_READER_API_KEY=

# Context7 上下文管理服务器
# 网址：https://mcp.context7.com/
MCP_CONTEXT7=false
