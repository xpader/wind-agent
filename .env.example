# Wind Framework 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# HTTP 服务器配置
HTTP_SERVER_LISTEN=0.0.0.0:2333

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wind_chat
DB_USERNAME=root
DB_PASSWORD=

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Tavily Search API 配置
# 获取 API 密钥：https://tavily.com/
TAVILY_API_KEY=
TAVILY_TIMEOUT=30
TAVILY_MAX_RESULTS=10

# MiniMax API 配置
# 获取 API 密钥：https://www.minimaxi.com/
MINIMAX_API_KEY=

# DeepSeek API 配置
# 获取 API 密钥：https://platform.deepseek.com/
DEEPSEEK_API_KEY=
